# MitPlan Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Firebase Configuration
# Get these values from: https://console.firebase.google.com/project/YOUR_PROJECT/settings/general
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Application Configuration
VITE_APP_NAME=MitPlan
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Collaboration Optimization
VITE_USE_OPTIMIZED_SYNC=true

# API Configuration (if using external APIs)
VITE_API_URL=http://localhost:3001/api
VITE_WEBSOCKET_URL=ws://localhost:3001

# Development Configuration
NODE_ENV=development
PORT=5173

# Optional: FFLogs API (if implementing FFLogs integration)
# VITE_FFLOGS_CLIENT_ID=your_fflogs_client_id
# VITE_FFLOGS_CLIENT_SECRET=your_fflogs_client_secret

# Optional: Analytics and Monitoring
# VITE_SENTRY_DSN=your_sentry_dsn
# VITE_GOOGLE_ANALYTICS_ID=your_ga_id
