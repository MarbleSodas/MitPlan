{
  "rules": {
    "userProfiles": {
      ".read": "auth != null",
      ".write": false,
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "plans": {
      ".read": "auth != null && ((query.orderByChild === 'ownerId' && query.equalTo === auth.uid) || (query.orderByChild === 'userId' && query.equalTo === auth.uid))",
      ".write": false,
      ".indexOn": ["userId", "ownerId"],
      "$planId": {
        ".read": "data.child('isPublic').val() === true || (auth != null && (data.child('ownerId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists()))",
        ".write": "auth != null && ((!data.exists() && newData.exists() && newData.child('ownerId').val() === auth.uid && newData.child('userId').val() === auth.uid) || (data.exists() && (data.child('ownerId').val() === auth.uid || data.child('userId').val() === auth.uid)))",
        "name": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "description": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "bossId": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "bossTags": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "bossMetadata": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "selectedJobs": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "assignments": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "tankPositions": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "healthSettings": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "timelineLayout": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "phaseOverrides": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "updatedAt": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "lastModifiedBy": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "lastChangeOrigin": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "lastAccessedAt": {
          ".write": "auth != null && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
        },
        "accessedBy": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid)",
          "$userId": {
            ".write": "auth != null && auth.uid === $userId && (root.child('plans').child($planId).child('isPublic').val() === true || root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('accessedBy').child(auth.uid).exists() || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists())"
          }
        }
      }
    },
    "planCollaboration": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$planId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "timelines": {
      ".read": false,
      ".write": false,
      ".indexOn": ["userId", "ownerId", "official", "isPublic", "likeCount"],
      "$timelineId": {
        ".read": "data.child('isPublic').val() === true || (auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid))",
        ".write": "(auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid || !data.exists())) && (data.child('official').val() !== true || !data.exists())",
        "likedBy": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    },
    "userCollections": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        "timelines": {
          ".read": "auth != null && auth.uid === $userId",
          ".write": "auth != null && auth.uid === $userId",
          "$timelineId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    }
  }
}
