{
  "rules": {
    "userProfiles": {
      ".read": "auth != null",
      ".write": false,
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "plans": {
      ".read": "auth != null && ((query.orderByChild === 'ownerId' && query.equalTo === auth.uid) || (query.orderByChild === 'userId' && query.equalTo === auth.uid))",
      ".write": false,
      ".indexOn": ["userId", "ownerId"],
      "$planId": {
        ".read": "data.child('isPublic').val() === true || (auth != null && (data.child('ownerId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('userProfiles').child(auth.uid).child('accessedPlans').child($planId).exists()))",
        ".write": "auth != null"
      }
    },
    "planCollaboration": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$planId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "timelines": {
      ".read": false,
      ".write": false,
      ".indexOn": ["userId", "ownerId", "official", "isPublic", "likeCount"],
      "$timelineId": {
        ".read": "data.child('isPublic').val() === true || (auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid))",
        ".write": "(auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid || !data.exists())) && (data.child('official').val() !== true || !data.exists())",
        "likedBy": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    },
    "userCollections": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        "timelines": {
          ".read": "auth != null && auth.uid === $userId",
          ".write": "auth != null && auth.uid === $userId",
          "$timelineId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    }
  }
}
