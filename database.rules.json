{
  "rules": {
    "userProfiles": {
      ".read": "auth != null",
      ".write": false,
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "plans": {
      ".read": "auth != null && ((query.orderByChild === 'ownerId' && query.equalTo === auth.uid) || (query.orderByChild === 'userId' && query.equalTo === auth.uid))",
      ".write": false,
      ".indexOn": ["userId", "ownerId"],
      "$planId": {
        ".read": "auth != null && (data.child('ownerId').val() === auth.uid || data.child('userId').val() === auth.uid || data.child('collaborators').child(auth.uid).child('role').val() === 'editor' || root.child('planCollaborationsByUser').child(auth.uid).child($planId).exists())",
        ".write": "auth != null && ((!data.exists() && newData.exists() && newData.child('ownerId').val() === auth.uid && newData.child('userId').val() === auth.uid) || (data.exists() && (data.child('ownerId').val() === auth.uid || data.child('userId').val() === auth.uid)))",
        "name": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "description": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "bossId": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "bossTags": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "bossMetadata": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "selectedJobs": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "assignments": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "tankPositions": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "healthSettings": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "timelineLayout": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "phaseOverrides": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "updatedAt": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "lastModifiedBy": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "lastChangeOrigin": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "lastAccessedAt": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "sourceTimelineId": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "sourceTimelineName": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
        },
        "isPublic": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid)"
        },
        "shareSettings": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid)"
        },
        "collaborators": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid)"
        },
        "accessedBy": {
          ".write": "auth != null && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid)",
          "$userId": {
            ".write": "auth != null && auth.uid === $userId && (root.child('plans').child($planId).child('ownerId').val() === auth.uid || root.child('plans').child($planId).child('userId').val() === auth.uid || root.child('plans').child($planId).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
          }
        }
      }
    },
    "planCollaborationsByUser": {
      ".read": "auth != null && query.orderByKey === true && query.equalTo === auth.uid",
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        "$planId": {
          ".write": "auth != null && root.child('plans').child($planId).child('ownerId').val() === auth.uid"
        }
      }
    },
    "planShareViews": {
      ".read": false,
      ".write": false,
      "$viewToken": {
        ".read": "data.child('viewEnabled').val() === true || (auth != null && (root.child('plans').child(data.child('planId').val()).child('ownerId').val() === auth.uid || root.child('plans').child(data.child('planId').val()).child('userId').val() === auth.uid || root.child('plans').child(data.child('planId').val()).child('collaborators').child(auth.uid).child('role').val() === 'editor'))",
        ".write": "auth != null && (root.child('plans').child((data.exists() ? data.child('planId').val() : newData.child('planId').val())).child('ownerId').val() === auth.uid || root.child('plans').child((data.exists() ? data.child('planId').val() : newData.child('planId').val())).child('userId').val() === auth.uid || root.child('plans').child((data.exists() ? data.child('planId').val() : newData.child('planId').val())).child('collaborators').child(auth.uid).child('role').val() === 'editor')"
      }
    },
    "planShareViewTracking": {
      ".read": false,
      ".write": false,
      "$viewToken": {
        "viewers": {
          ".read": "auth != null && (root.child('plans').child(root.child('planShareViews').child($viewToken).child('planId').val()).child('ownerId').val() === auth.uid || root.child('plans').child(root.child('planShareViews').child($viewToken).child('planId').val()).child('userId').val() === auth.uid || root.child('plans').child(root.child('planShareViews').child($viewToken).child('planId').val()).child('collaborators').child(auth.uid).child('role').val() === 'editor')",
          "$userId": {
            ".write": "auth != null && auth.uid === $userId && root.child('planShareViews').child($viewToken).child('viewEnabled').val() === true"
          }
        }
      }
    },
    "planCollaboration": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$planId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "timelines": {
      ".read": "(query.orderByChild === 'isPublic' && query.equalTo === true) || (auth != null && ((query.orderByChild === 'userId' && query.equalTo === auth.uid) || (query.orderByChild === 'ownerId' && query.equalTo === auth.uid)))",
      ".write": false,
      ".indexOn": ["userId", "ownerId", "official", "isPublic", "likeCount"],
      "$timelineId": {
        ".read": "data.child('isPublic').val() === true || (auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid))",
        ".write": "(auth != null && (data.child('userId').val() === auth.uid || data.child('ownerId').val() === auth.uid || !data.exists())) && (data.child('official').val() !== true || !data.exists())",
        "likedBy": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$userId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    },
    "userCollections": {
      ".read": false,
      ".write": false,
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId",
        "timelines": {
          ".read": "auth != null && auth.uid === $userId",
          ".write": "auth != null && auth.uid === $userId",
          "$timelineId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId"
          }
        }
      }
    }
  }
}
